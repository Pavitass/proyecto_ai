# Copia a .env en helpdesk_agent/ o usa el .env del taller (IA_WORKSHOPS/.env)

# --- Chat (elige un proveedor) ---
# DeepSeek (OpenAI-compatible). Si está definida, el agente usa DeepSeek.
DEEPSEEK_API_KEY=
# Opcional: URL base (por defecto https://api.deepseek.com)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Google Gemini (recomendado: chat + embeddings + visión con la misma clave)
GOOGLE_API_KEY=

# Forzar proveedor de chat: auto | deepseek | google
# HELPDESK_LLM=auto

# HELPDESK_CHAT_MODEL=deepseek-chat
# HELPDESK_CHAT_MODEL=deepseek-v4-flash
# HELPDESK_CHAT_MODEL=gemini-2.0-flash

# --- Embeddings para RAG ---
# auto: si hay GOOGLE_API_KEY → embeddings Google; si no → HuggingFace local (sin clave).
# Forzar: HELPDESK_EMBEDDINGS=google | hf
# HELPDESK_EMBEDDINGS=auto

# Solo si embeddings Google:
# HELPDESK_EMBEDDING_MODEL=models/text-embedding-004

# Solo si embeddings HF (modelo multilingüe por defecto):
# HELPDESK_HF_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Visión (capturas): por defecto Google Gemini ---
# Requiere GOOGLE_API_KEY. Las capturas se describen y el texto va al agente (aunque el chat sea DeepSeek).
# HELPDESK_VISION_BACKEND=google
# HELPDESK_VISION_MODEL=gemini-2.0-flash
# Solo si quieres otro proveedor con API tipo OpenAI (GPT-4o, OpenRouter…):
# HELPDESK_VISION_BACKEND=openai
# HELPDESK_VISION_OPENAI_API_KEY=...
# HELPDESK_VISION_OPENAI_BASE_URL=https://api.openai.com/v1
# HELPDESK_VISION_OPENAI_MODEL=gpt-4o-mini
